# ==========================================
# Document Intelligence Refinery Environment
# ==========================================

# ------------------------------------------
# LLM Provider Configuration (Stage 4 & 5)
# Used for PageIndex Summaries, FactTable Extraction, and Query Agent reasoning.
# ------------------------------------------

# Options: ollama, openai, gemini
LLM_PROVIDER=ollama
# Recommended Ollama: qwen2.5:latest or qwen3.5:latest
# Recommended OpenAI: gpt-4o-mini
# Recommended Gemini: gemini-2.0-flash
LLM_MODEL=qwen3.5:397b-cloud
OLLAMA_BASE_URL=http://localhost:11434

# ------------------------------------------
# VLM Provider Configuration (Stage 2 - Strategy C)
# Used for Vision-augmented extraction when OCR/layout rules trigger.
# ------------------------------------------

# Options: ollama, openai, gemini
VLM_PROVIDER=ollama
# Recommended Ollama: llava
# Recommended OpenAI: gpt-4o-mini
# Recommended Gemini: gemini-2.5-flash
VLM_MODEL=qwen3.5:397b-cloud

# ------------------------------------------
# API Keys (Required if using OpenAI or Gemini)
# ------------------------------------------
OPENAI_API_KEY=your_openai_key_here
GOOGLE_API_KEY=your_google_key_here
OPENROUTER_API_KEY=your_openrouter_key_here

# ------------------------------------------
# General Configurations
# ------------------------------------------
REFINERY_CONFIG_PATH=rubric/extraction_rules.yaml
# LOG_LEVEL=DEBUG 
